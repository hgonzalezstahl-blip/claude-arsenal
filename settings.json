{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/dashboard-launch.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:3001/hooks/claude"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/protect-sensitive-files.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/tdd-enforcement.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/agent-audit.js"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:3001/hooks/claude"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/detect-prompt-injection.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/truncate-large-output.sh"
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/tool-audit.js"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/auto-format.sh"
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/tool-audit.js"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/audit-log.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/truncate-large-output.sh"
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/tool-audit.js"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/agent-audit.js"
          }
        ]
      },
      {
        "matcher": "Grep|Glob|Skill",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/tool-audit.js"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:3001/hooks/claude"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-end.sh"
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/session-report.js"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:3001/hooks/claude"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/notify-windows.sh"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:3001/hooks/claude"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:3001/hooks/claude"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:3001/hooks/claude"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:3001/hooks/claude"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:3001/hooks/claude"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:3001/hooks/claude"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:3001/hooks/claude"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:3001/hooks/claude"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:3001/hooks/claude"
          }
        ]
      }
    ],
    "Elicitation": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:3001/hooks/claude"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "insecure-defaults@trailofbits": true,
    "static-analysis@trailofbits": true,
    "supply-chain-risk-auditor@trailofbits": true,
    "sharp-edges@trailofbits": true,
    "property-based-testing@trailofbits": true,
    "mutation-testing@trailofbits": true,
    "second-opinion@trailofbits": true,
    "compound-engineering@compound-engineering-plugin": true,
    "semgrep-rule-creator@trailofbits": true,
    "variant-analysis@trailofbits": true,
    "differential-review@trailofbits": true,
    "entry-point-analyzer@trailofbits": true,
    "skill-improver@trailofbits": true,
    "audit-context-building@trailofbits": true,
    "security-guidance@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "session-report@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "claude-mem@thedotmack": true
  },
  "extraKnownMarketplaces": {
    "trailofbits": {
      "source": {
        "source": "github",
        "repo": "trailofbits/skills"
      }
    },
    "compound-engineering-plugin": {
      "source": {
        "source": "github",
        "repo": "EveryInc/compound-engineering-plugin"
      }
    },
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    }
  },
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true
}
