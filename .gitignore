# Session data and transcripts (private, large)
projects/
sessions/
file-history/

# Caches and temp files
cache/
paste-cache/
image-cache/
shell-snapshots/

# Sensitive files — NEVER commit these
.credentials.json
mcp-needs-auth-cache.json
settings.local.json
audit.log
history.jsonl
telemetry/
security_warnings_*.json

# Plugin runtime data (installed separately, auto-updated by Claude Code)
plugins/cache/
plugins/data/
plugins/blocklist.json
plugins/installed_plugins.json
plugins/known_marketplaces.json

# Settings (auto-updated by Claude Code per session)
settings.json

# IDE state
ide/

# Task state (ephemeral)
tasks/

# Downloads
downloads/

# Agent memory (project-specific, pushed separately per project)
agent-memory/

# Backups
backups/

# Runtime audit data (generated per-session, not config)
agent-audit.jsonl
tool-audit.jsonl
session-reports/
session-env/

# External tools (installed separately)
tools/

# Echo personal voice profile (samples stay local, never pushed)
agents/echo/style-profile.md

# Pitch personal career data (master CV + active job target stay local)
agents/pitch/master-cv.md
agents/pitch/job-target.md
